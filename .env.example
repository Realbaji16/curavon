# Curavon environment variables (Next.js)
# Copy to .env.local for local development. Never commit secrets.

# App environment: development | test | staging | production
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Auth mode: local_demo (development only) or supabase (required for pilot/production)
NEXT_PUBLIC_AUTH_MODE=local_demo

# Supabase — browser-safe publishable key only (no service_role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only AI (never expose via NEXT_PUBLIC_*)
AI_ENABLED=false
AI_PROVIDER=openai-compatible
OPENAI_API_KEY=

# Optional — server-only; REQUIRED for full account deletion (never NEXT_PUBLIC_*)
# SUPABASE_SERVICE_ROLE_KEY=

# Legacy Vite names (migration fallback only — prefer NEXT_PUBLIC_*)
# VITE_AUTH_MODE=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
