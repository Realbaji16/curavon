# Curavon environment variables (Next.js)
# Copy to .env.local for local development. Never commit secrets.

# Curavon is now a Next.js app.
# Browser-exposed env variables must use NEXT_PUBLIC_*.
# Never expose Supabase service_role or secret keys in frontend env.
# Keep real values in .env.local, not committed source files.

# Auth mode: local_demo (default) or supabase
NEXT_PUBLIC_AUTH_MODE=local_demo

# Supabase — browser-safe publishable key only (no service_role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional OpenAI key for governed AI features (client-side in this prototype)
NEXT_PUBLIC_OPENAI_API_KEY=

# Legacy Vite names (migration fallback only — prefer NEXT_PUBLIC_*)
# VITE_AUTH_MODE=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_OPENAI_API_KEY=
