  "required_questions": [
    {
      "id": "medicine_name",
      "prompt": "What is the medicine name, as written on the pack or receipt if you know it?",
      "kind": "required"
    },
    {
      "id": "medicine_source",
      "prompt": "Where did it come from — doctor, pharmacy, chemist, friend, or home?",
      "kind": "required"
    },
    {
      "id": "when_taken",
      "prompt": "When did you take it (or when was it given)?",
      "kind": "required"
    },
    {
      "id": "times_taken_history",
      "prompt": "Roughly how many times have you taken it so far? This is only to record history — not for changing how you take it.",
      "kind": "required"
    },
    {
      "id": "changes_after",
      "prompt": "What changed after taking it — better, worse, itching, swelling, weakness, or no change?",
      "kind": "required"
    },
    {
      "id": "allergies",
      "prompt": "Do you have any known medicine or food allergies?",
      "kind": "required"
    },
    {
      "id": "conditions_context",
      "prompt": "Any current health conditions, pregnancy, or is this for a child?",
      "kind": "required"
    },
    {
      "id": "packaging_photo",
      "prompt": "Do you have the packaging, label, receipt, or a photo of the medicine?",
      "kind": "required"
    }
