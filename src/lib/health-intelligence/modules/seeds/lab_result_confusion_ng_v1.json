{
  "module_id": "lab_result_confusion_ng_v1",
  "name": "Lab result confusion",
  "country_context": "NG",
  "risk_level": "medium_high",
  "status": "review",
  "version": "1.1.0",
  "purpose": "Help users organize lab slips and confusion about results — including Widal, malaria, typhoid, blood, urine, and scan reports — for clinician review, not interpretation as illness or treatment decisions.",
  "not_allowed": [
    "Interpreting Widal titre numbers as confirming typhoid or Salmonella infection",
    "Saying malaria positive or reactive means disease without clinician context and symptoms",
    "Diagnosing malaria, typhoid, infection, or any named condition from a lab slip",
    "Prescribing antibiotics, antimalarials, or any treatment based on result wording alone",
    "Declaring results normal or abnormal without clinician context",
    "Recommending dosage or dose changes based on lab wording alone",
    "Replacing emergency services when the person is very unwell regardless of slip wording"
  ],
