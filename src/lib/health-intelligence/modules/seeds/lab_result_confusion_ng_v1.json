  "required_questions": [
    {
      "id": "test_name",
      "prompt": "What is the test name as written on the slip or report?",
      "kind": "required"
    },
    {
      "id": "test_date",
      "prompt": "When was the test done (date)?",
      "kind": "required"
    },
    {
      "id": "who_ordered",
      "prompt": "Who ordered the test — a clinician, self-requested, chemist, or employer screening?",
      "kind": "required"
    },
    {
      "id": "symptoms_led_to_test",
      "prompt": "What symptoms led you to do this test, and what are you noticing now?",
      "kind": "required"
    },
    {
      "id": "unclear_wording",
      "prompt": "What part of the result is confusing you (words, numbers, positive/reactive flags)?",
      "kind": "required"
    },
    {
      "id": "full_result_available",
      "prompt": "Do you have the full result, slip photo, or complete report available?",
      "kind": "required"
    },
    {
      "id": "medicine_from_result",
      "prompt": "Have you started any new medicines because of this result?",
      "kind": "required"
    },
    {
      "id": "symptoms_worsening",
      "prompt": "Are your symptoms getting worse since the test was done?",
      "kind": "required"
    }
  ],
  "ai_generated_question_policy": {
    "enabled": true,
    "maxAdditionalQuestions": 2,
    "mustStayWithinModuleScope": true,
    "forbiddenTopics": [
      "widal interpretation",
      "diagnosis from labs",
      "treatment choice",
      "prescription",
      "normal or abnormal conclusion",
      "malaria proof from labs"
    ],
    "notes": "Organize slip details, symptoms, and questions for a clinician — never conclude illness from numbers or reactive flags alone."
  },
  "allowed_actions": [
    {
      "id": "organize_test_details",
      "title": "Organize test name, date, and facility",
      "instruction": "Write test name, date done, facility name, and who ordered it — without guessing what the result means.",
      "category": "track",
      "safetyLevel": "low"
    },
    {
      "id": "link_symptom_timeline",
      "title": "Link result to symptom timeline",
      "instruction": "Note when symptoms started, when the test was done, and how symptoms changed before and after the result.",
      "category": "track",
      "safetyLevel": "low"
    },
    {
      "id": "prepare_clinician_questions",
      "title": "Prepare clinician questions",
      "instruction": "List questions about what the test checks, how it fits your symptoms, and what follow-up is needed — without naming an illness.",
      "category": "prepare",
      "safetyLevel": "medium"
    },
    {
      "id": "prepare_lab_followup_summary",
      "title": "Prepare lab follow-up summary",
      "instruction": "Organize test name, date, confusing wording, current symptoms, and medicines started for a clinician or lab follow-up visit.",
      "category": "prepare",
      "safetyLevel": "medium"
    },
    {
      "id": "avoid_self_treat_from_slip",
      "title": "Avoid self-treatment from slip alone",
      "instruction": "If medicines were started only because of slip wording, note what was taken and ask a clinician or pharmacist before adding more.",
      "category": "prepare",
      "safetyLevel": "medium_high"
    },
    {
      "id": "seek_urgent_if_unwell",
      "title": "Seek urgent care if very unwell",
      "instruction": "If breathing is hard, confusion appears, severe pain occurs, or you feel very unwell regardless of the slip, seek emergency care now.",
      "category": "seek_care",
      "safetyLevel": "urgent"
    }
  ],
  "summary_fields": [
